# ============================================================
# kiwi-mem 环境变量配置
# ============================================================
# 复制此文件为 .env 并填入你的值
# cp .env.example .env

# ---- 必填 ----

# LLM API Key（OpenRouter / OpenAI / AIHubMix / 其他）
API_KEY=sk-your-api-key-here

# LLM API 地址
API_BASE_URL=https://openrouter.ai/api/v1/chat/completions

# PostgreSQL 连接串（开启记忆系统时必填）
DATABASE_URL=postgresql://user:password@localhost:5432/kiwi_mem

# ---- 可选 ----

# 记忆系统开关（默认关闭，配好数据库后改为 true）
MEMORY_ENABLED=false

# 默认聊天模型
DEFAULT_MODEL=anthropic/claude-sonnet-4

# 网关端口
PORT=8080

# 管理面板密码（不设则无需密码，建议生产环境设置）
ACCESS_TOKEN=

# 每次注入的最大记忆条数
MAX_MEMORIES_INJECT=15

# 记忆提取间隔（每 N 轮对话提取一次）
MEMORY_EXTRACT_INTERVAL=3

# 前端域名白名单（逗号分隔，CORS 用）
CORS_ORIGINS=http://localhost:5173,http://localhost:5174

# jieba 自定义分词词汇（逗号分隔，适合添加人名、专有名词）
JIEBA_CUSTOM_WORDS=

# OpenRouter 需要的额外请求头
EXTRA_REFERER=https://ai-memory-gateway.local
EXTRA_TITLE=AI Memory Gateway
